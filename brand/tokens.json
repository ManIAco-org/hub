{
  "$schema": "https://maniaco.design/token-schema/v1",
  "version": "1.0.0",
  "meta": {
    "name": "ManIAcos Design Tokens",
    "description": "Design tokens for the ManIAcos Hub and public landing. Dark-native.",
    "updated": "2026-05-25"
  },

  "color": {
    "base": {
      "bg":     { "value": "#0A0A0A", "comment": "App background" },
      "s1":     { "value": "#111111", "comment": "Sidebar, topbar, floating panels" },
      "s2":     { "value": "#1A1A1A", "comment": "Cards, dropdowns, tooltips" },
      "s3":     { "value": "#242424", "comment": "Hover states, active inputs" },
      "border": { "value": "#262626", "comment": "Card borders, separators" },
      "bsub":   { "value": "#181818", "comment": "Subtle borders, internal dividers" }
    },

    "text": {
      "t1": { "value": "#EFEFEF", "comment": "Primary text — headings, important labels" },
      "t2": { "value": "#8A8F9E", "comment": "Secondary text — metadata, subtitles" },
      "t3": { "value": "#525866", "comment": "Tertiary text — placeholders, disabled" }
    },

    "cyan": {
      "50":  { "value": "#ECFEFF" },
      "100": { "value": "#CFFAFE" },
      "200": { "value": "#A5F3FC" },
      "300": { "value": "#67E8F9" },
      "400": { "value": "#22D3EE" },
      "500": { "value": "#06B6D4", "comment": "Brand — primary accent" },
      "600": { "value": "#0891B2" },
      "700": { "value": "#0E7490" },
      "800": { "value": "#155E75" },
      "900": { "value": "#164E63" },
      "alpha-10": { "value": "rgba(6,182,212,0.10)", "comment": "Badge backgrounds, subtle fills" },
      "alpha-25": { "value": "rgba(6,182,212,0.25)", "comment": "Selected state backgrounds" },
      "alpha-40": { "value": "rgba(6,182,212,0.40)", "comment": "Focus rings" }
    },

    "lime": {
      "400": { "value": "#A3E635", "comment": "Running/live state ONLY" },
      "alpha-10": { "value": "rgba(163,230,53,0.10)", "comment": "Running badge bg" },
      "alpha-22": { "value": "rgba(163,230,53,0.22)", "comment": "Running badge border" }
    },

    "green": {
      "500": { "value": "#22C55E", "comment": "Success — build ok, tests pass, deploy ok" },
      "alpha-10": { "value": "rgba(34,197,94,0.10)" },
      "alpha-22": { "value": "rgba(34,197,94,0.22)" }
    },

    "yellow": {
      "500": { "value": "#F59E0B", "comment": "Warning — HITL pending, slow CI, risk" },
      "alpha-10": { "value": "rgba(245,158,11,0.10)" },
      "alpha-22": { "value": "rgba(245,158,11,0.22)" }
    },

    "red": {
      "500": { "value": "#EF4444", "comment": "Error — test fail, deploy rollback, CI error" },
      "alpha-10": { "value": "rgba(239,68,68,0.10)" },
      "alpha-22": { "value": "rgba(239,68,68,0.22)" }
    },

    "black": { "value": "#000000", "comment": "Button text on cyan background" },
    "white": { "value": "#FFFFFF" }
  },

  "font": {
    "family": {
      "ui":      { "value": "'Instrument Sans', system-ui, sans-serif", "comment": "All Hub UI" },
      "mono":    { "value": "'Geist Mono', 'Courier New', monospace", "comment": "Numbers, code, IDs, timestamps" },
      "display": { "value": "'Fraunces', Georgia, serif", "comment": "Landing h1 ONLY — never in Hub" }
    },

    "size": {
      "xs":   { "value": "11px" },
      "sm":   { "value": "12px" },
      "base": { "value": "13px" },
      "md":   { "value": "14px" },
      "lg":   { "value": "16px" },
      "xl":   { "value": "20px" },
      "2xl":  { "value": "24px" },
      "3xl":  { "value": "32px" },
      "hero": { "value": "clamp(48px, 6vw, 72px)", "comment": "Landing h1 only" }
    },

    "weight": {
      "normal":   { "value": "400" },
      "medium":   { "value": "500" },
      "semibold": { "value": "600" },
      "bold":     { "value": "700" },
      "black":    { "value": "900", "comment": "Hero only" }
    },

    "lineHeight": {
      "tight":  { "value": "1.2" },
      "snug":   { "value": "1.3" },
      "normal": { "value": "1.4" },
      "relaxed":{ "value": "1.5" },
      "loose":  { "value": "1.6", "comment": "Terminal/mono" }
    },

    "letterSpacing": {
      "tight":  { "value": "-0.01em" },
      "normal": { "value": "0" },
      "wide":   { "value": "0.06em", "comment": "Table headers uppercase" },
      "wider":  { "value": "0.08em", "comment": "Breadcrumbs uppercase" }
    }
  },

  "spacing": {
    "0":  { "value": "0px" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" },
    "20": { "value": "80px" },
    "24": { "value": "96px" }
  },

  "borderRadius": {
    "none": { "value": "0px" },
    "sm":   { "value": "4px",    "comment": "Inline badges, inputs" },
    "md":   { "value": "6px",    "comment": "Buttons, tooltips, tags" },
    "lg":   { "value": "8px",    "comment": "Dropdowns, small modals" },
    "xl":   { "value": "12px",   "comment": "Cards, sidebar pills, panels" },
    "2xl":  { "value": "16px",   "comment": "Large modals, sheets" },
    "full": { "value": "9999px", "comment": "Status pills, avatars" }
  },

  "boxShadow": {
    "sm":   { "value": "0 1px 3px rgba(0,0,0,0.4)",           "comment": "Cards at rest" },
    "md":   { "value": "0 4px 12px rgba(0,0,0,0.5)",          "comment": "Cards on hover, dropdowns" },
    "lg":   { "value": "0 8px 24px rgba(0,0,0,0.6)",          "comment": "Modals, floating panels" },
    "cyan": { "value": "0 0 0 2px rgba(6,182,212,0.4)",        "comment": "Focus ring, active elements" },
    "run":  { "value": "0 0 0 2px rgba(163,230,53,0.35)",      "comment": "Live/running glow" }
  },

  "layout": {
    "sidebarWidth":         { "value": "192px" },
    "sidebarWidthExpanded": { "value": "240px" },
    "fileTreeWidth":        { "value": "168px" },
    "topbarHeight":         { "value": "48px" },
    "statusBarHeight":      { "value": "36px" },
    "contentMaxWidth":      { "value": "1200px" }
  },

  "zIndex": {
    "base":    { "value": "0" },
    "raised":  { "value": "10" },
    "dropdown":{ "value": "100" },
    "sticky":  { "value": "200" },
    "overlay": { "value": "300" },
    "modal":   { "value": "400" },
    "toast":   { "value": "500" }
  },

  "transition": {
    "fast":   { "value": "100ms ease" },
    "normal": { "value": "150ms ease" },
    "slow":   { "value": "250ms ease" }
  }
}
