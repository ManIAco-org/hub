# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─── Terminal Service ────────────────────────────────────────────────────────
# Prod: wss://term.maniaco.online
# Dev:  ws://localhost:3001  (run terminal-service locally with docker compose)
NEXT_PUBLIC_TERMINAL_URL=wss://term.maniaco.online

# ─── Vercel API (Panel 5 — Deploys) ─────────────────────────────────────────
# Get from: vercel.com → Settings → Tokens
# Only needed for Panel 5 (Deploys). Safe to leave blank during M1/M2 dev.
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
