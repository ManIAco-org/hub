# ManIAcos Terminal Service — environment variables
# Copy to .env and fill in values from Vaultwarden
# NEVER commit .env

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Project Settings → API → Project URL
SUPABASE_URL=https://teyqamjfsfewusqjcfcy.supabase.co

# Project Settings → API → service_role key (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Service config ────────────────────────────────────────────────────────────
PORT=3001

# ── Linux user IDs on Oracle ARM ──────────────────────────────────────────────
# Run on Oracle: id franco   → shows uid=XXXX gid=XXXX
# Run on Oracle: id lucho    → shows uid=XXXX gid=XXXX
# Run on Oracle: id noe      → shows uid=XXXX gid=XXXX
UID_FRANCO=1000
GID_FRANCO=1000
UID_LUCHO=1001
GID_LUCHO=1001
UID_NOE=1002
GID_NOE=1002
